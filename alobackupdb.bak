329	<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">৫</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">টাকায়</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">২টি</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">করে</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">কমলা</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">কিনে</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">৩৫</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">টাকায়</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">কয়টি</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">কমলা</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">বিক্রয়</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">করলে</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">৪০</span></span><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">% </span></span><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">লাভ</span></span> <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">হবে</span></span><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">?</span></span></span></span></p>\r\n	1306	<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><strong>&nbsp;&nbsp;&nbsp;&nbsp;</strong>&nbsp; <span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">২টি কমলার ক্রয়মূল্য ৫টাকা</span></span></span></span></p>\r\n\r\n<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; ১টি&nbsp; &ldquo;&nbsp;&nbsp;&nbsp;&nbsp; &ldquo;&nbsp;&nbsp;&nbsp; ৫/২ &ldquo;</span></span></span></span></p>\r\n\r\n<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">এখন ৪০% লাভে বিক্রয়মূল্য = ১০০+৪০ = ১৪০ টাকা</span></span></span></span></p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">&nbsp; ক্রয়মূল্য ১০০ টাকা হলে বিক্রয়মূল্য ১৪০ টাকা</span></span></span></span></p>\r\n\r\n<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">&nbsp; &ldquo;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; ১&nbsp; &ldquo;&nbsp;&nbsp;&nbsp; &ldquo;&nbsp;&nbsp;&nbsp; &ldquo;&nbsp;&nbsp; ১৪০/১০০ &ldquo;</span></span></span></span></p>\r\n\r\n<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">&nbsp; &ldquo;&nbsp;&nbsp;&nbsp;&nbsp; ৫/২&nbsp; &ldquo;&nbsp;&nbsp; &ldquo;&nbsp;&nbsp;&nbsp; &ldquo;&nbsp; = [১৪০ &times; ৫] / [১০০ &times; ২] = ৭/২ টাকা</span></span></span></span></p>\r\n\r\n<p>&nbsp;</p>\r\n\r\n<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">&nbsp; আবার, ৭/২ টাকায় বিক্রয় করা যায় ১ টি</span></span></span></span></p>\r\n\r\n<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; ১&nbsp;&nbsp; &ldquo;&nbsp;&nbsp;&nbsp;&nbsp; &ldquo;&nbsp;&nbsp; &ldquo;&nbsp;&nbsp; &ldquo; ২/৭ টি</span></span></span></span></p>\r\n\r\n<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; ৩৫&nbsp; &ldquo;&nbsp;&nbsp;&nbsp;&nbsp; &ldquo;&nbsp;&nbsp;&nbsp; &ldquo;&nbsp;&nbsp;&nbsp; &ldquo; ২</span></span> <em><span style="font-size:16.0pt"><span style="font-family:&quot;Cambria Math&quot;,&quot;serif&quot;">&times; </span></span></em><span style="font-size:11.0pt"><span style="font-family:&quot;Calibri&quot;,&quot;sans-serif&quot;"><img id="_x0000_i1025" src="data:image/png;base64," style="height:20.25pt; width:15pt" /> </span></span><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">৩৫ / ৭ </span></span></span></span></p>\r\n\r\n<p><span style="font-size:11pt"><span style="font-family:Calibri,sans-serif"><span style="font-size:16.0pt"><span style="font-family:&quot;Vrinda&quot;,&quot;sans-serif&quot;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; = ১০ টি </span></span></span></span></p>\r\n	0	83	2021-01-29 11:13:53.641375+00
